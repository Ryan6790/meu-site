<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bella Pizza - As Melhores Pizzas Artesanais</title>
    <style>
        /* --- VARIÁVEIS E CONFIGURAÇÕES GERAIS --- */
        :root {
            --primary-color: #ff3838;
            --primary-hover: #d63031;
            --secondary-color: #2ed573;
            --dark-color: #2d3436;
            --light-color: #f7f1e3;
            --white: #ffffff;
            --shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--light-color);
            color: var(--dark-color);
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* --- HEADER / TOPO --- */
        header {
            background-color: var(--white);
            box-shadow: var(--shadow);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
        }

        header .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            color: var(--primary-color);
        }

        .cart-btn {
            background-color: var(--primary-color);
            color: var(--white);
            border: none;
            padding: 10px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
        }

        .cart-btn:hover {
            background-color: var(--primary-hover);
        }

        /* --- HERO SECTION / BANNER PRINCIPAL --- */
        .hero {
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://unsplash.com') center/cover no-repeat;
            height: 80vh;
            display: flex;
            align-items: center;
            color: var(--white);
            text-align: center;
            margin-top: 60px;
        }

        .hero-content h1 {
            font-size: 48px;
            margin-bottom: 20px;
        }

        .hero-content p {
            font-size: 20px;
            margin-bottom: 30px;
        }

        .cta-btn {
            background-color: var(--secondary-color);
            color: var(--white);
            text-decoration: none;
            padding: 15px 35px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 30px;
            transition: 0.3s;
            display: inline-block;
        }

        .cta-btn:hover {
            transform: scale(1.05);
            background-color: #26af5f;
        }

        /* --- CARDÁPIO / PRODUTOS --- */
        .menu-section {
            padding: 80px 0;
        }

        .section-title {
            text-align: center;
            font-size: 36px;
            margin-bottom: 40px;
            color: var(--dark-color);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .card {
            background-color: var(--white);
            border-radius: 15px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: 0.3s;
            display: flex;
            flex-direction: column;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .card-img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .card-body {
            padding: 20px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .card-title {
            font-size: 22px;
            margin-bottom: 10px;
        }

        .card-desc {
            font-size: 14px;
            color: #666;
            margin-bottom: 20px;
            flex-grow: 1;
        }

        .card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .price {
            font-size: 20px;
            font-weight: bold;
            color: var(--primary-color);
        }

        .add-to-cart {
            background-color: var(--dark-color);
            color: var(--white);
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
            transition: 0.3s;
        }

        .add-to-cart:hover {
            background-color: var(--primary-color);
        }

        /* --- MODAL DO CARRINHO --- */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.7);
            z-index: 2000;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background-color: var(--white);
            padding: 30px;
            border-radius: 15px;
            max-width: 500px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            position: relative;
        }

        .close-modal {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 28px;
            cursor: pointer;
        }

        .cart-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #ddd;
        }

        .cart-total {
            margin-top: 20px;
            font-size: 20px;
            font-weight: bold;
            text-align: right;
        }

        .checkout-btn {
            display: block;
            width: 100%;
            background-color: var(--secondary-color);
            color: var(--white);
            border: none;
            padding: 12px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 5px;
            margin-top: 20px;
            cursor: pointer;
        }

        /* --- RODAPÉ --- */
        footer {
            background-color: var(--dark-color);
            color: var(--white);
            text-align: center;
            padding: 30px 20px;
            margin-top: 40px;
        }

        /* --- RESPONSIVIDADE --- */
        @media (max-width: 768px) {
            .hero-content h1 { font-size: 32px; }
            .hero-content p { font-size: 16px; }
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header>
        <div class="container">
            <div class="logo">🍕 Bella Pizza</div>
            <button class="cart-btn" onclick="toggleModal(true)">🛒 Carrinho (<span id="cart-count">0</span>)</button>
        </div>
    </header>

    <!-- HERO SECTION -->
    <section class="hero">
        <div class="container hero-content">
            <h1>A Verdadeira Pizza Artesanal</h1>
            <p>Massa de fermentação lenta, ingredientes selecionados e assada no forno a lenha.</p>
            <a href="#cardapio" class="cta-btn">Ver Cardápio & Pedir</a>
        </div>
    </section>

    <!-- CARDÁPIO -->
    <section class="menu-section" id="cardapio">
        <div class="container">
            <h2 class="section-title">Nossas Pizzas Mais Pedidas</h2>
            
            <div class="grid">
                <!-- Pizza 1 -->
                <div class="card">
                    <img src="https://unsplash.com" alt="Pizza Margherita" class="card-img">
                    <div class="card-body">
                        <h3 class="card-title">Margherita Premium</h3>
                        <p class="card-desc">Molho de tomate artesanal, muçarela de búfala, manjericão fresco e azeite extravirgem.</p>
                        <div class="card-footer">
                            <span class="price">R$ 45,00</span>
                            <button class="add-to-cart" onclick="addToCart('Margherita Premium', 45.00)">+ Adicionar</button>
                        </div>
                    </div>
                </div>

                <!-- Pizza 2 -->
                <div class="card">
                    <img src="https://unsplash.com" alt="Pizza Calabresa" class="card-img">
                    <div class="card-body">
                        <h3 class="card-title">Calabresa Especial</h3>
                        <p class="card-desc">Molho de tomate, muçarela, calabresa defumada artesanal e cebola roxa marinada.</p>
                        <div class="card-footer">
                            <span class="price">R$ 42,00</span>
                            <button class="add-to-cart" onclick="addToCart('Calabresa Especial', 42.00)">+ Adicionar</button>
                        </div>
                    </div>
                </div>

                <!-- Pizza 3 -->
                <div class="card">
                    <img src="https://unsplash.com" alt="Pizza Quatro Queijos" class="card-img">
                    <div class="card-body">
                        <h3 class="card-title">Quatro Formaggi</h3>
                        <p class="card-desc">Combinação perfeita de muçarela, provolone, gorgonzola marcante e catupiry original.</p>
                        <div class="card-footer">
