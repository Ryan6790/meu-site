<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Motors Prime - Concessionária Digital</title>
    
    <!-- 🎨 ESTILOS INTEGRADOS (CSS) -->
    <style>
        /* Reset Geral e Variáveis */
        :root {
            --primary: #e74c3c;
            --primary-dark: #c0392b;
            --dark: #1a1a1a;
            --light: #f5f6fa;
            --gray: #7f8c8d;
            --white: #ffffff;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--light);
            color: var(--dark);
        }

        /* Menu / Cabeçalho */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 10%;
            background-color: rgba(26, 26, 26, 0.98);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .logo {
            font-size: 26px;
            font-weight: 800;
            color: var(--white);
            letter-spacing: 1px;
        }

        .logo span {
            color: var(--primary);
        }

        .nav a {
            text-decoration: none;
            color: #dcdde1;
            margin-right: 25px;
            font-weight: 500;
            transition: color 0.3s;
        }

        .nav a:hover {
            color: var(--primary);
        }

        /* Banner Principal (Hero Section) com Imagem de Fundo */
        .hero-section {
            height: 85vh;
            background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.7)), 
                              url('');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            padding: 0 10%;
            color: var(--white);
            padding-top: 80px;
        }

        .hero-content {
            max-width: 600px;
        }

        .hero-content h1 {
            font-size: 52px;
            line-height: 1.2;
            margin-bottom: 20px;
            font-weight: 800;
        }

        .hero-content p {
            font-size: 18px;
            margin-bottom: 30px;
            color: #bdc3c7;
        }

        .btn-main {
            display: inline-block;
            background-color: var(--primary);
            color: var(--white);
            text-decoration: none;
            padding: 15px 35px;
            border-radius: 5px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: background 0.3s, transform 0.2s;
        }

        .btn-main:hover {
            background-color: var(--primary-dark);
            transform: translateY(-2px);
        }

        /* Grid de Veículos (Catálogo) */
        .catalog-section {
            padding: 80px 10%;
            text-align: center;
        }

        .catalog-section h2 {
            font-size: 36px;
            margin-bottom: 10px;
            font-weight: 700;
        }

        .catalog-subtitle {
            color: var(--gray);
            margin-bottom: 50px;
            font-size: 16px;
        }

        .car-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        .car-card {
            background: var(--white);
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            transition: transform 0.3s, box-shadow 0.3s;
            text-align: left;
        }

        .car-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .car-img-box {
            width: 100%;
            height: 200px;
            overflow: hidden;
        }

        .car-img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s;
        }

        .car-card:hover .car-img-box img {
            transform: scale(1.05);
        }

        .car-info {
            padding: 25px;
        }

        .car-tag {
            background-color: #edf2f7;
            color: #4a5568;
            padding: 4px 10px;
            font-size: 12px;
            font-weight: bold;
            border-radius: 4px;
            display: inline-block;
            margin-bottom: 12px;
        }

        .car-info h3 {
            font-size: 22px;
            margin-bottom: 10px;
            color: #2d3748;
        }

        .car-specs {
            display: flex;
            justify-content: space-between;
            color: var(--gray);
            font-size: 14px;
            margin-bottom: 20px;
            border-bottom: 1px solid #edf2f7;
            padding-bottom: 15px;
        }

        .car-price-box {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .car-price {
            font-size: 24px;
            font-weight: 700;
            color: var(--primary);
        }

        .btn-buy {
            background-color: var(--dark);
            color: var(--white);
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s;
        }

        .btn-buy:hover {
            background-color: var(--primary);
        }

        /* Rodapé */
        .footer {
            background-color: var(--dark);
            color: #a0aec0;
            text-align: center;
            padding: 40px 20px;
            font-size: 14px;
            margin-top: 60px;
            border-top: 3px solid var(--primary);
        }

        @media (max-width: 768px) {
            .hero-section {
                text-align: center;
                justify-content: center;
                padding: 0 5%;
            }
            .hero-content h1 {
                font-size: 38px;
            }
        }
    </style>
</head>
<body>

